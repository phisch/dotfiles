{
    "position": "top",
    "layer": "top",
    "height": 32,
    "spacing": 0,
    "fixed-center": false,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": ["bluetooth", "network", "pulseaudio", "battery", "backlight", "cpu", "memory", "temperature", "clock", "tray"],
    "sway/window": {
        "max-length": 50,
        "max-length-mode": "middle",
        "tooltip": true
    },
    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "format": "",
        "persistent_workspaces": {
            "1": ["eDP-1", "DP-3"],
            "2": ["eDP-1", "DP-3"],
            "3": ["eDP-1", "DP-3"],
            "4": ["eDP-1", "DP-3"],
            "5": ["eDP-1", "DP-3"],
            "6": ["DP-1", "DP-3"],
            "7": ["DP-1"],
            "8": ["DP-1"],
            "9": ["DP-1"],
            "10": ["DP-1"]
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "timezone": "Europe/Berlin",
        "format": "َ°…گ {:%a %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "َ°…گ {:%a %d.%m.%Y %H:%M}"
    },
    "cpu": {
        "format": "َ°کڑ {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "َ°چ› {}%"
    },
