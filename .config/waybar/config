        "on-click": "light -S 0.1",
        "on-scroll-up": "light -A 1",
        "on-scroll-down": "light -U 1",
        "smooth-scrolling-threshold": 2.0
    },
    "battery": {
        "interval": 10,
        "states": {
            "critical": 25
        },
        "format": "{icon} {capacity}%",
